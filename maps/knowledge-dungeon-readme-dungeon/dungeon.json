  "rooms": {
    "root-overview": {
      "roomId": "root-overview",
      "topic": "Knowledge Dungeon Overview",
      "createdAt": "2026-06-04T20:02:32.228Z",
      "updatedAt": "2026-06-04T20:02:32.228Z",
      "state": "Created",
      "notePath": "rooms/room-root-overview/notes.txt",
      "artifactPath": "rooms/room-root-overview/artifact.md",
      "noteText": "Summary\nKnowledge Dungeon is a local-first, offline-friendly study dungeon-crawler that combines a room-based mindmap with structured note-taking and review.\n\nKey Points\n- It merges the repo-dungeon engine with mindmap-dungeon's learning model.\n- Learners clear rooms by writing notes that pass deterministic quality gates.\n- Clearing all rooms unlocks Archaeologist review prompts and streak tracking.\n\nRecall Question\nHow does Knowledge Dungeon turn studying into an interactive progression loop?",
      "artifactMarkdown": null,
      "validationState": {
        "wordCount": 0,
        "requiredSectionsPresent": false,
        "manualConfirmed": false,
        "criterionScores": {
          "sectionCompleteness": 0,
